# Required environment variables — must be set in Vercel (or any host) before deploying.
# Copy this file to .env.local for local development. NEVER commit .env.local.

# Anthropic API key — get it from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# === Stripe — cobros del coach (Jesús/KING) → Tower + invitación automática ===
# Clave secreta (o restringida) de la cuenta Stripe DEL COACH.
# Stripe Dashboard → Developers → API keys.
STRIPE_SECRET_KEY=sk_live_...
# Signing secret del webhook (Stripe Dashboard → Developers → Webhooks → tu endpoint → "Signing secret").
STRIPE_WEBHOOK_SECRET=whsec_...
# Llave interna server-to-server: el webhook de Stripe la usa para disparar /api/send-invite.
# Generá una cadena random larga, por ej: openssl rand -hex 32
INTERNAL_API_KEY=
