{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "coachaipro.com" }],
      "destination": "https://coachaipro.ai/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.coachaipro.com" }],
      "destination": "https://coachaipro.ai/$1",
      "permanent": true
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "tower.coachaipro.ai" }],
      "destination": "/tower/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/guia",
      "destination": "/guia.html"
    },
    {
      "source": "/jesus",
      "destination": "/index.html"
    },
    {
      "source": "/king",
      "destination": "/index.html"
    },
    {
      "source": "/studio",
      "destination": "/studio/index.html"
    }
  ],
  "crons": [
    { "path": "/api/cron-notifications", "schedule": "*/30 * * * *" }
  ]
}
