{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "coachaipro.com" }],
      "destination": "https://coachaipro.ai/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.coachaipro.com" }],
      "destination": "https://coachaipro.ai/$1",
      "permanent": true
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "tower.coachaipro.ai" }],
      "destination": "/tower/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/.well-known/assetlinks.json",
      "destination": "/assetlinks.json"
    },
    {
      "source": "/guia",
      "destination": "/guia.html"
    },
    {
      "source": "/manual-coach",
      "destination": "/manual-coach.html"
    },
    {
      "source": "/jesus",
      "destination": "/index.html"
    },
    {
      "source": "/king",
      "destination": "/index.html"
    },
    {
      "source": "/studio",
      "destination": "/studio/index.html"
    }
  ],
  "headers": [
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=()" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors 'self'; object-src 'none'; base-uri 'self'" }
      ]
    }
  ]
}
